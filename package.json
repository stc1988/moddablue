{
	"name": "moddablue",
	"version": "1.0.0",
	"private": true,
	"description": "Bluetooth Low Energy services and applications built with the Moddable SDK.",
	"scripts": {
		"build:sim": "cd examples/ams-media-player && mcconfig -d -m -p sim",
		"build:ancs:sim": "cd examples/ancs-notifications && mcconfig -d -m -p sim",
		"build:hid:sim": "cd examples/hid-keyboard && mcconfig -d -m -p sim",
		"build:hid:esp32": "cd examples/hid-keyboard && mcconfig -d -m -p esp32/moddable_two",
		"build:hid-media:sim": "cd examples/hid-media-control && mcconfig -d -m -p sim",
		"build:hid-media:esp32": "cd examples/hid-media-control && mcconfig -d -m -p esp32/moddable_two",
		"debug:sim": "cd examples/ams-media-player && mcconfig -dl -m -p sim",
		"debug:ancs:sim": "cd examples/ancs-notifications && mcconfig -dl -m -p sim",
		"debug:hid:sim": "cd examples/hid-keyboard && mcconfig -dl -m -p sim",
		"debug:hid-media:sim": "cd examples/hid-media-control && mcconfig -dl -m -p sim",
		"extract-font-chars": "node scripts/extract-font-chars.js",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"moddable",
		"bluetooth",
		"ble",
		"ams",
		"ancs",
		"hid"
	],
	"author": "Satoshi Tanaka",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@moddable/typings": "^8.3.0",
		"fontkit": "^2.0.4",
		"typescript": "^5.9.3"
	}
}
