{
	"name": "moddable-mediaplayer",
	"version": "1.0.0",
	"private": true,
	"description": "240x320 display-first Moddable Piu media player scaffold for Apple Media Service work.",
	"scripts": {
		"build:sim": "cd src && mcconfig -d -m -p sim",
		"debug:sim": "cd src && mcconfig -dl -m -p sim",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [],
	"author": "Satoshi Tanaka",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@moddable/typings": "^8.3.0",
		"typescript": "^5.9.3"
	}
}
